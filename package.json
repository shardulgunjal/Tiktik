{
  "name": "tiktik",
  "version": "0.1.0",
  "type": "module",
  "description": "Dynamic Island-style notification/toast library for web applications. Zero dependencies. Vanilla JS + TypeScript + WAAPI.",
  "main": "./dist/tiktik.cjs",
  "module": "./dist/tiktik.es.js",
  "browser": "./dist/tiktik.umd.js",
  "types": "./dist/types.d.ts",
  "exports": {
    ".": {
      "import": "./dist/tiktik.es.js",
      "require": "./dist/tiktik.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "toast",
    "notification",
    "dynamic-island",
    "snackbar",
    "vanilla-js",
    "typescript",
    "waapi",
    "zero-dependencies"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
